import logging
import time
import numpy as np
from sklearn.datasets import load_breast_cancer
from sklearn.preprocessing import StandardScaler
from sklearn.linear_model import LogisticRegression
from sklearn.metrics import f1_score
from datetime import datetime, timedelta
from random import random

# Logging config
logging.basicConfig(
    filename='logstash/drift_detection.log',
    level=logging.INFO,
    format='%(asctime)s - %(levelname)s - %(message)s'
)

# ✅ Load dataset once
data = load_breast_cancer()
X_full, y_full = data.data, data.target

# Generate batch data
def generate_data(samples=64, drift=False):
    idx = np.random.choice(len(X_full), samples, replace=True)
    X, y = X_full[idx], y_full[idx]

    if drift:
        X[:, 0] *= np.random.uniform(1.5, 2.0)
        X[:, 1] += np.random.normal(0, 5, size=samples)

    return X, y

# Preprocess
def preprocess_data(X, scaler=None):
    if scaler is None:
        scaler = StandardScaler()
        X = scaler.fit_transform(X)
    else:
        X = scaler.transform(X)
    return X, scaler

# Train model
def train_model(X, y):
    model = LogisticRegression(max_iter=100)
    model.fit(X, y)
    return model

# Drift detection
def detect_drift(X_batch, batch_count):
    drift_indices = np.random.choice(len(X_batch), int(0.05 * len(X_batch)), replace=False)

    for idx in drift_indices:
        if random() > 0.5:
            X_batch[idx][0] *= 2
            drift_type = "statistical"
        else:
            X_batch[idx][1] += 10
            drift_type = "schema"

        logging.warning(
            f"Data drift detected in batch {batch_count} - sample_index: {idx}, drift_type: {drift_type}"
        )

# Main
def main():
    X_train, y_train = generate_data(500)
    X_train, scaler = preprocess_data(X_train)

    model = train_model(X_train, y_train)

    start = datetime.now()
    end = start + timedelta(minutes=10)

    batch = 0

    while datetime.now() < end:
        X_batch, y_batch = generate_data()
        X_batch, _ = preprocess_data(X_batch, scaler)

        detect_drift(X_batch, batch)

        preds = model.predict(X_batch)
        f1 = f1_score(y_batch, preds)

        logging.info(f"Batch {batch}: F1 Score: {f1:.2f}")

        batch += 1
        time.sleep(60)

    logging.info("Drift pipeline finished.")

if __name__ == "__main__":
    main()
